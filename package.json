{
  "name": "tc39-mcp",
  "version": "0.1.0",
  "private": false,
  "description": "Structured MCP server for the TC39 specs (ECMA-262 + ECMA-402) — SHA-pinned clauses, AOID-aware search, in+out cross-references, edition diffs, history.",
  "type": "module",
  "bin": {
    "tc39-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist/",
    "build/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/mcp/server.js",
    "typecheck": "tsc --noEmit",
    "fetch-spec": "bash scripts/fetch-spec.sh",
    "fetch-test262": "bash scripts/fetch-test262.sh",
    "parse": "tsx src/parser/cli.ts",
    "build-test262-index": "tsx src/index/build_test262.ts",
    "fetch-proposals": "bash scripts/fetch-proposals.sh",
    "build-proposals-index": "tsx src/index/build_proposals.ts",
    "mcp": "tsx src/mcp/server.ts",
    "test": "vitest run",
    "docs:data": "tsx src/docs/build_data.ts",
    "docs:dev": "npm run docs:data && vitepress dev docs",
    "docs:build": "npm run docs:data && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tc39/ecma262-biblio": "^2.2.3000",
    "cheerio": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "ecmascript",
    "ecma262",
    "ecma402",
    "tc39",
    "intl",
    "javascript-spec",
    "specification",
    "language-spec",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xyzzylabs/tc39-mcp.git"
  },
  "homepage": "https://github.com/xyzzylabs/tc39-mcp",
  "bugs": "https://github.com/xyzzylabs/tc39-mcp/issues"
}
