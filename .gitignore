node_modules/
dist/
build/
vendor/
.DS_Store
*.log

# Cloudflare Workers / Wrangler artifacts
.wrangler/
.wrangler-state/
.wrangler-dryrun/
worker/node_modules/
worker/.wrangler/
worker/.wrangler-state/
# `wrangler types` regenerates this from worker/wrangler.toml on demand.
# Keeping it untracked avoids merge churn when bindings change.
worker/worker-configuration.d.ts

# VitePress docs site build outputs
docs/.vitepress/dist/
docs/.vitepress/cache/

# Auto-generated docs pages, produced by `npm run docs:data` (which
# `docs:dev` and `docs:build` chain into).
#   - snapshots.md: rendered from `build/spec-*.json` pin headers;
#     changes every refresh (cron-bumped PATCH), so untracked.
#   - changelog.md: verbatim copy of the repo-root CHANGELOG.md so
#     VitePress can route it. Untracked — `CHANGELOG.md` is the
#     source of truth.
# tools.md is intentionally tracked so a fresh clone (or anyone
# browsing the repo on GitHub) gets the full tool reference without
# needing to run `npm run docs:data` first.
docs/snapshots.md
docs/changelog.md

# Staging directory the deploy workflow copies the built docs into so
# wrangler can bundle them as Worker static assets. Gitignored;
# regenerated on every deploy.
worker/public/
